generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Placeholder model — full schema will be created in Session 2 (M1-02)
model HealthCheck {
  id        Int      @id @default(autoincrement())
  status    String   @default("ok")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("health_checks")
}
