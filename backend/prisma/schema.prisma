generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum Role {
  admin
  operator
  viewer
}

enum UserStatus {
  active
  inactive
  pending_invite
}

enum ContactStatus {
  active
  inactive
  dnc
  invalid
}

enum CampaignStatus {
  draft
  scheduled
  running
  paused
  completed
  cancelled
}

enum CallOutcome {
  success
  no_answer
  busy
  voicemail
  failed
  callback_requested
  dnc_requested
}

enum CustomFieldType {
  text
  number
  boolean
  date
}

enum TemplateCategory {
  cobranca
  vendas
  pesquisa
  confirmacao
  notificacao
}

// ==================== MODELS ====================

model Plan {
  id             String    @id @default(uuid())
  name           String    @unique
  price          Decimal   @db.Decimal(10, 2)
  maxUsers       Int       @map("max_users")
  maxContacts    Int       @map("max_contacts")
  maxCampaigns   Int       @map("max_campaigns_month")
  maxCallsMonth  Int       @map("max_calls_month")
  maxPhoneLines  Int       @map("max_phone_lines")
  features       Json      @default("{}")
  isCustom       Boolean   @default(false) @map("is_custom")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  companies Company[]

  @@map("plans")
}

model Company {
  id               String    @id @default(uuid())
  name             String
  cnpj             String?   @unique
  planId           String    @map("plan_id")
  stripeCustomerId String?   @unique @map("stripe_customer_id")
  isActive         Boolean   @default(true) @map("is_active")
  timezone         String    @default("America/Sao_Paulo")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  plan             Plan      @relation(fields: [planId], references: [id])
  users            User[]
  contacts         Contact[]
  tags             Tag[]
  customFields     CustomField[]
  templates        CompanyTemplate[]
  phoneLines       PhoneLine[]
  campaigns        Campaign[]
  auditLogs        AuditLog[]
  usageRecords     UsageRecord[]

  @@map("companies")
}

model User {
  id              String     @id @default(uuid())
  companyId       String     @map("company_id")
  email           String     @unique
  passwordHash    String     @map("password_hash")
  name            String
  role            Role       @default(operator)
  status          UserStatus @default(active)
  inviteToken     String?    @unique @map("invite_token")
  inviteExpiresAt DateTime?  @map("invite_expires_at")
  resetToken      String?    @unique @map("reset_token")
  resetExpiresAt  DateTime?  @map("reset_expires_at")
  sessionVersion  Int        @default(1) @map("session_version")
  lastLoginAt     DateTime?  @map("last_login_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  company         Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  campaigns       Campaign[] @relation("CampaignCreator")
  auditLogs       AuditLog[]

  @@index([companyId])
  @@map("users")
}

model Tag {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  name      String
  color     String   @default("#6B7280")
  createdAt DateTime @default(now()) @map("created_at")

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contacts     ContactTag[]
  campaignTags CampaignTag[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("tags")
}

model CustomField {
  id        String          @id @default(uuid())
  companyId String          @map("company_id")
  name      String
  label     String
  type      CustomFieldType @default(text)
  isRequired Boolean        @default(false) @map("is_required")
  createdAt DateTime        @default(now()) @map("created_at")

  company  Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  values   ContactFieldValue[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("custom_fields")
}

model Contact {
  id             String        @id @default(uuid())
  companyId      String        @map("company_id")
  fullName       String        @map("full_name")
  primaryPhone   String        @map("primary_phone")
  secondaryPhone String?       @map("secondary_phone")
  email          String?
  organization   String?
  status         ContactStatus @default(active)
  notes          String?
  lastContactAt  DateTime?     @map("last_contact_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  company        Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tags           ContactTag[]
  fieldValues    ContactFieldValue[]
  campaignContacts CampaignContact[]
  callLogs       CallLog[]

  @@unique([primaryPhone, companyId])
  @@index([companyId])
  @@index([companyId, status])
  @@map("contacts")
}

model ContactTag {
  contactId String @map("contact_id")
  tagId     String @map("tag_id")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@map("contact_tags")
}

model ContactFieldValue {
  id            String @id @default(uuid())
  contactId     String @map("contact_id")
  customFieldId String @map("custom_field_id")
  value         String

  contact     Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  customField CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([contactId, customFieldId])
  @@map("contact_field_values")
}

model Template {
  id          String           @id @default(uuid())
  name        String
  description String?
  category    TemplateCategory
  isGlobal    Boolean          @default(true) @map("is_global")
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  versions         TemplateVersion[]
  companyTemplates CompanyTemplate[]

  @@map("templates")
}

model TemplateVersion {
  id         String   @id @default(uuid())
  templateId String   @map("template_id")
  version    Int      @default(1)
  steps      Json
  variables  Json     @default("[]")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  template  Template   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  @@unique([templateId, version])
  @@map("template_versions")
}

model CompanyTemplate {
  id         String   @id @default(uuid())
  companyId  String   @map("company_id")
  templateId String   @map("template_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([companyId, templateId])
  @@map("company_templates")
}

model PhoneLine {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  phoneNumber   String   @unique @map("phone_number")
  retellAgentId String?  @map("retell_agent_id")
  label         String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  @@index([companyId])
  @@map("phone_lines")
}

model Campaign {
  id                String         @id @default(uuid())
  companyId         String         @map("company_id")
  name              String
  description       String?
  templateVersionId String         @map("template_version_id")
  phoneLineId       String         @map("phone_line_id")
  createdById       String         @map("created_by_id")
  status            CampaignStatus @default(draft)
  scheduledAt       DateTime?      @map("scheduled_at")
  startedAt         DateTime?      @map("started_at")
  completedAt       DateTime?      @map("completed_at")
  maxRetries        Int            @default(3) @map("max_retries")
  retryIntervalMin  Int            @default(60) @map("retry_interval_min")
  concurrentCalls   Int            @default(1) @map("concurrent_calls")
  totalContacts     Int            @default(0) @map("total_contacts")
  completedCalls    Int            @default(0) @map("completed_calls")
  successfulCalls   Int            @default(0) @map("successful_calls")
  failedCalls       Int            @default(0) @map("failed_calls")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  templateVersion TemplateVersion @relation(fields: [templateVersionId], references: [id])
  phoneLine       PhoneLine       @relation(fields: [phoneLineId], references: [id])
  createdBy       User            @relation("CampaignCreator", fields: [createdById], references: [id])
  contacts        CampaignContact[]
  tags            CampaignTag[]
  callLogs        CallLog[]

  @@index([companyId])
  @@index([companyId, status])
  @@map("campaigns")
}

model CampaignContact {
  id         String       @id @default(uuid())
  campaignId String       @map("campaign_id")
  contactId  String       @map("contact_id")
  outcome    CallOutcome?
  attempts   Int          @default(0)
  lastCallAt DateTime?    @map("last_call_at")
  notes      String?
  createdAt  DateTime     @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id])

  @@unique([campaignId, contactId])
  @@index([campaignId])
  @@map("campaign_contacts")
}

model CampaignTag {
  campaignId String @map("campaign_id")
  tagId      String @map("tag_id")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([campaignId, tagId])
  @@map("campaign_tags")
}

model CallLog {
  id                String      @id @default(uuid())
  campaignId        String      @map("campaign_id")
  contactId         String      @map("contact_id")
  retellCallId      String?     @unique @map("retell_call_id")
  phoneNumberUsed   String      @map("phone_number_used")
  outcome           CallOutcome?
  durationSeconds   Int?        @map("duration_seconds")
  transcript        Json?
  sentiment         String?
  intentDetected    String?     @map("intent_detected")
  retellRawResponse Json?       @map("retell_raw_response")
  startedAt         DateTime?   @map("started_at")
  endedAt           DateTime?   @map("ended_at")
  createdAt         DateTime    @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id])

  @@index([campaignId])
  @@index([contactId])
  @@map("call_logs")
}

model AuditLog {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  userId    String   @map("user_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  details   Json?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([companyId, entity])
  @@map("audit_logs")
}

model UsageRecord {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  date      DateTime @db.Date
  calls     Int      @default(0)
  minutes   Decimal  @default(0) @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, date])
  @@index([companyId])
  @@map("usage_records")
}

model HelpCategory {
  id        String        @id @default(uuid())
  name      String        @unique
  icon      String?
  order     Int           @default(0)
  createdAt DateTime      @default(now()) @map("created_at")

  articles HelpArticle[]

  @@map("help_categories")
}

model HelpArticle {
  id         String   @id @default(uuid())
  categoryId String   @map("category_id")
  title      String
  content    String
  order      Int      @default(0)
  isPublished Boolean @default(true) @map("is_published")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  category HelpCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("help_articles")
}
